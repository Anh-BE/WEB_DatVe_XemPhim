@model doan3.Models.DoiMatKhauViewModel

@{
    ViewBag.Title = "Đổi Mật Khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* --- FONT & GENERAL --- */
    .movana-font {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* KHUNG BAO NGOÀI */
    .password-wrapper {
        max-width: 800px; /* Giảm width một chút để form dọc nhìn cân đối hơn */
        margin: 60px auto;
    }

    /* --- PREMIUM CARD --- */
    .premium-card {
        background: #15183c;
        border: 1px solid rgba(249, 224, 0, 0.15);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        padding: 50px;
        position: relative;
        border-radius: 16px;
    }

    /* TIÊU ĐỀ */
    .section-title {
        color: #f9e000;
        font-weight: 900;
        font-size: 2rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 10px;
        text-align: left;
    }

    .sub-title {
        text-align: left;
        color: #8899a6;
        font-size: 0.95rem;
        margin-bottom: 40px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 20px;
    }

    /* FORM ELEMENTS */
    .form-group {
        margin-bottom: 30px;
    }

    .label-custom {
        color: #8899a6;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        display: block;
    }

        .label-custom i {
            color: #f9e000;
            margin-right: 8px;
        }

    /* INPUT STYLE PREMIUM */
    .input-premium {
        background: #0a0d29;
        border: 1px solid #2a2d55;
        color: #fff;
        height: 55px;
        border-radius: 10px;
        padding: 0 20px;
        font-weight: 600;
        font-size: 1rem;
        width: 100%;
        transition: all 0.3s;
    }

        .input-premium:focus {
            background: #0a0d29;
            border-color: #f9e000;
            color: #fff;
            box-shadow: 0 0 15px rgba(249, 224, 0, 0.15);
            outline: none;
        }

    /* NÚT BẤM */
    .btn-action-group {
        display: flex;
        gap: 20px;
        margin-top: 40px;
        justify-content: flex-end;
    }

    .btn-gold {
        background: #f9e000;
        color: #060922;
        border: none;
        height: 50px;
        padding: 0 40px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 10px;
        transition: all 0.3s;
        text-decoration: none !important;
        display: flex;
        align-items: center;
    }

        .btn-gold:hover {
            background: #e0c900;
            transform: translateY(-2px);
            color: #000;
        }

    .btn-back {
        background: transparent;
        color: #fff;
        border: 1px solid #444;
        height: 50px;
        padding: 0 30px;
        font-weight: 700;
        text-transform: uppercase;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none !important;
        transition: all 0.3s;
    }

        .btn-back:hover {
            background: #2c3e50;
            border-color: #fff;
            color: #fff;
        }

    /* VALIDATION ERROR */
    .text-danger {
        color: #ff6b6b !important;
        font-size: 0.85rem;
        margin-top: 8px;
        display: block;
        font-weight: 500;
    }

    .validation-summary-errors {
        background: rgba(220, 53, 69, 0.1);
        border-radius: 10px;
        border: 1px solid #dc3545;
        color: #ff6b6b;
        padding: 15px;
        margin-bottom: 30px;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }
</style>

<div class="container movana-font">
    <div class="password-wrapper">
        <div class="premium-card">

            <h2 class="section-title"><i class="fa fa-shield-alt mr-3"></i> ĐỔI MẬT KHẨU</h2>
            <p class="sub-title"></p>

            @using (Html.BeginForm("DoiMatKhau", "ThongTinCaNhan", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                    

                @* 1. Mật khẩu hiện tại (TRÊN CÙNG) *@
                <div class="form-group">
                    <label class="label-custom"><i class="fa fa-key"></i> MẬT KHẨU HIỆN TẠI</label>
                    @Html.PasswordFor(model => model.MatKhauCu, new { @class = "input-premium", placeholder = "Nhập mật khẩu đang sử dụng..." })
                    @Html.ValidationMessageFor(model => model.MatKhauCu, "", new { @class = "text-danger" })
                </div>

                @* 2. Mật khẩu mới (Ở GIỮA) *@
                <div class="form-group">
                    <label class="label-custom"><i class="fa fa-unlock-alt"></i> MẬT KHẨU MỚI</label>
                    @Html.PasswordFor(model => model.MatKhauMoi, new { @class = "input-premium", placeholder = "Nhập mật khẩu mới..." })
                    @Html.ValidationMessageFor(model => model.MatKhauMoi, "", new { @class = "text-danger" })
                </div>

                @* 3. Xác nhận mật khẩu (DƯỚI CÙNG) *@
                <div class="form-group">
                    <label class="label-custom"><i class="fa fa-check-circle"></i> XÁC NHẬN MẬT KHẨU</label>
                    @Html.PasswordFor(model => model.XacNhanMatKhau, new { @class = "input-premium", placeholder = "Nhập lại mật khẩu mới..." })
                    @Html.ValidationMessageFor(model => model.XacNhanMatKhau, "", new { @class = "text-danger" })
                </div>

                <div class="btn-action-group">
                    <a href="@Url.Action("Index", "ThongTinCaNhan")" class="btn btn-back">
                        <i class="fa fa-arrow-left mr-2"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-gold">
                        <i class="fa fa-save mr-2"></i> LƯU THAY ĐỔI
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}