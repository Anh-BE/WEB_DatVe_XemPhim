@model IEnumerable<doan3.Models.Phim>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Tìm kiếm phim";
    // Ép kiểu kết quả tìm kiếm từ ViewBag, nếu null thì tạo list rỗng để tránh lỗi crash
    var dsKetQua = (ViewBag.Result as List<doan3.Models.Phim>) ?? new List<doan3.Models.Phim>();
}

<div class="content-wrapper-search">
    @if (dsKetQua.Any())
    {
        <div class="section-header-search">
            <h2 class="title-silver">@ViewBag.Message</h2>
        </div>

        <div class="phim-grid-container">
            @foreach (var s in dsKetQua)
            {
                <div class="phim-card-item">
                    <div class="img-container">
                        <img src="@Url.Content("~/Content/HinhAnhSP/" + s.Poster)" alt="@s.TenPhim" />
                    </div>
                    <div class="phim-content">
                        <p class="phim-name-text">@s.TenPhim</p>
                        <div class="phim-action-group">
                            <a href="@Url.Action("ChiTietPhim", "Home", new { id = s.PhimID })" class="btn-movana-sm">Chi Tiết</a>
                            <a href="@Url.Action("ChonSuat", "DatVe", new { idPhim = s.PhimID })" class="btn-movana-sm">Đặt Vé</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-result-wrapper">
            <div class="section-header-search">
                <h2 class="title-silver">KHÔNG TÌM THẤY PHIM</h2>
            </div>
            <p class="message-text">@ViewBag.Message</p>
            <div class="btn-center-box">
                <a href="@Url.Action("PhimDangChieu", "Home")" class="btn-movana-lg">QUAY VỀ TRANG CHỦ</a>
            </div>
        </div>

        <div class="recommend-box">
            <div class="section-header-search">
                <h2 class="title-silver">CÓ THỂ BẠN SẼ THÍCH</h2>
            </div>
            <div class="phim-grid-container">
                @foreach (var s in Model)
                {
                    <div class="phim-card-item">
                        <div class="img-container">
                            <img src="@Url.Content("~/Content/HinhAnhSP/" + s.Poster)" alt="@s.TenPhim" />
                        </div>
                        <div class="phim-content">
                            <p class="phim-name-text">@s.TenPhim</p>
                            <div class="phim-action-group">
                                <a href="@Url.Action("ChiTietPhim", "Home", new { id = s.PhimID })" class="btn-movana-sm">Chi Tiết</a>
                                <a href="@Url.Action("ChonSuat", "DatVe", new { idPhim = s.PhimID })" class="btn-movana-sm">Đặt Vé</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    /* RESET & FONT */
    .content-wrapper-search {
        max-width: 1300px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    /* TIÊU ĐỀ CHUẨN XANH BẠC MOVANA */
    .section-header-search {
        margin-bottom: 30px;
        text-align: center;
    }

    .title-silver {
        font-family: 'Montserrat', sans-serif !important;
        font-weight: 700 !important;
        font-size: 26px !important;
        color: #adc1ff !important;
        text-transform: uppercase !important;
        letter-spacing: 2px !important;
        display: inline-block !important;
        position: relative !important;
        padding-bottom: 15px !important;
        text-shadow: 0 0 10px rgba(173, 193, 255, 0.3) !important;
        margin: 0 !important;
    }

        .title-silver::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 3px;
            background-color: #ffeb00 !important;
            border-radius: 2px;
        }

    /* KHỐI KHÔNG CÓ KẾT QUẢ */
    .no-result-wrapper {
        text-align: center;
        padding: 60px 20px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 20px;
        margin-bottom: 60px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .message-text {
        color: #ccc;
        font-size: 18px;
        margin-bottom: 30px !important;
    }

    .btn-center-box {
        display: flex;
        justify-content: center;
    }

    /* GRID CẤU TRÚC PHIM */
    .phim-grid-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .phim-card-item {
        background-color: #1a1a2e;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s ease;
        border: 1px solid rgba(255,255,255,0.05);
        text-align: center;
    }

        .phim-card-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.5);
            border-color: #ffeb00;
        }

    .img-container img {
        width: 100%;
        height: 320px;
        object-fit: cover;
    }

    .phim-content {
        padding: 15px;
    }

    .phim-name-text {
        font-weight: 600;
        color: #fff;
        font-size: 1rem;
        margin-bottom: 15px !important;
        height: 2.5rem;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    /* NÚT BẤM (Xóa gạch chân & Hover quét màu) */
    .phim-action-group {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

    .btn-movana-sm, .btn-movana-lg {
        position: relative !important;
        display: inline-block !important;
        background: #ffeb00 !important;
        color: #000 !important;
        font-weight: 700 !important;
        text-decoration: none !important; /* Xóa gạch chân */
        text-transform: uppercase !important;
        overflow: hidden !important;
        z-index: 1 !important;
        border: none !important;
        transition: color 0.3s ease !important;
        text-align: center !important;
    }

    .btn-movana-sm {
        flex: 1;
        padding: 8px 0 !important;
        font-size: 13px !important;
        border-radius: 8px !important;
    }

    .btn-movana-lg {
        padding: 12px 40px !important;
        font-size: 16px !important;
        border-radius: 30px !important;
    }

        /* HIỆU ỨNG HOVER QUÉT MÀU */
        .btn-movana-sm::before, .btn-movana-lg::before {
            content: "" !important;
            position: absolute !important;
            inset: 0 !important;
            background: linear-gradient(90deg, #7f00ff, #3a7bd5) !important;
            transform: translateX(-105%) !important;
            transition: transform 0.45s ease-in-out !important;
            z-index: -1 !important;
        }

        .btn-movana-sm:hover::before, .btn-movana-lg:hover::before {
            transform: translateX(0) !important;
        }

        .btn-movana-sm:hover, .btn-movana-lg:hover {
            color: #fff !important;
            text-decoration: none !important;
            box-shadow: 0 5px 15px rgba(127, 0, 255, 0.4) !important;
        }

    /* Responsive cho mobile */
    @@media (max-width: 992px) {
        .phim-grid-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>