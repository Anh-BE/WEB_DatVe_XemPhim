@{
    ViewBag.Title = "Chưa có lịch chiếu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container text-center py-5">
    <i class="fas fa-film fa-4x mb-3 text-warning"></i>

    <h3 class="mt-3">
        Phim hiện chưa có lịch chiếu
    </h3>

    <p class="text-muted">
        Vui lòng quay lại sau hoặc chọn phim khác.
    </p>

    <a href="@Url.Action("PhimDangChieu", "Home")"
       class="btn btn-warning font-weight-bold mt-3">
        Quay lại trang chủ
    </a>
</div>
